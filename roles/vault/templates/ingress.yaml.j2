---
# Vault UI + API ingress.
#
# Vault's compiled JS hard-codes /v1/ and /ui/ as absolute paths, so a
# sub-path prefix (e.g. /vault) cannot work without rewriting the JS bundle.
# Vault is therefore served at the root of a dedicated subdomain
# (vault_ingress_host), where all paths are native and need no rewriting.
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: vault-ingress
  namespace: {{ vault_namespace }}
  annotations:
    nginx.ingress.kubernetes.io/backend-protocol: "HTTP"
    # Force HTTPS redirect
    nginx.ingress.kubernetes.io/force-ssl-redirect: "true"
{% if vault_ingress_use_cert_manager | default(false) | bool %}
    cert-manager.io/cluster-issuer: "{{ vault_ingress_cluster_issuer }}"
{% endif %}
spec:
  ingressClassName: "{{ vault_ingress_class }}"
  rules:
    - host: "{{ vault_ingress_host }}"
      http:
        paths:
          # Vault UI (Ember.js app at /ui/…)
          - path: /ui
            pathType: Prefix
            backend:
              service:
                name: vault-ui
                port:
                  number: 8200
          # Vault HTTP API (/v1/…) – called directly by the UI's JS bundle
          - path: /v1
            pathType: Prefix
            backend:
              service:
                name: vault-active
                port:
                  number: 8200
          # Root redirect: / → /ui (Vault itself handles this redirect)
          - path: /
            pathType: Prefix
            backend:
              service:
                name: vault-ui
                port:
                  number: 8200
{% if vault_ingress_tls_secret %}
  tls:
    - hosts:
        - "{{ vault_ingress_host }}"
      secretName: "{{ vault_ingress_tls_secret }}"
{% endif %}
